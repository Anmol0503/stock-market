# Copy to .env and fill in. Never commit .env.

# Finnhub free API key (https://finnhub.io) — news + earnings/economic calendars.
# Optional: the fetcher still runs without it (skips Finnhub sources).
FINNHUB_API_KEY=

# Gmail send (turn on 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords — 16 chars, no spaces).
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_TO=you@gmail.com

# Public URL of your GitHub Pages dashboard (used as a link in the email).
DASHBOARD_URL=https://YOURUSERNAME.github.io/stock-market/

# --- Social / Instagram carousels (make_social.py) — all optional ---
# Branding on the generated post slides + captions.
SOCIAL_HANDLE=@daily.decoded
SOCIAL_BIO_LINK=Full decoded feed → link in bio
# Monetization hooks — leave BLANK to keep them OFF (they only appear if set).
SPONSOR_LINE=
AFFILIATE_URL=
# Phase 2 (auto-posting via the official Meta Graph Content Publishing API) — unused today.
# Needs an Instagram Business/Creator account + a Facebook app + long-lived tokens.
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_TOKEN=
